PORT=3300

# Mongo is optional but recommended for durability.
MONGO_URL=
MONGO_DB=guesstheai
MONGO_EVENTS_COLLECTION=da_gateway_events
MONGO_BATCHES_COLLECTION=da_gateway_batches

# Queue/batching behavior
DA_BATCH_SIZE=50
DA_FLUSH_INTERVAL_MS=5000
DA_EVENT_MAX_AGE_MS=120000

# Delivery mode:
# - local: single-service mode (recommended) -> uses DA_WRITER_MODE below
# - mock/http/grpc: legacy direct modes
DA_TARGET_MODE=local

# HTTP upstream target (used when DA_TARGET_MODE=http)
DA_UPSTREAM_URL=
DA_UPSTREAM_API_KEY=
DA_TIMEOUT_MS=12000

# gRPC target placeholders (used when DA_TARGET_MODE=grpc)
DA_GRPC_ENDPOINT=127.0.0.1:51001
DA_GRPC_PROTO_PATH=
DA_GRPC_SERVICE=
DA_GRPC_METHOD=

# Single-service writer mode for DA_TARGET_MODE=local
# - mock: stores mock refs (testing)
# - http: forwards from this service to a DA writer upstream
# - grpc: direct DA client gRPC call from this service
DA_WRITER_MODE=mock
DA_WRITER_UPSTREAM_URL=
DA_WRITER_UPSTREAM_API_KEY=
DA_WRITER_GRPC_ENDPOINT=127.0.0.1:51001
DA_WRITER_GRPC_PROTO_PATH=
DA_WRITER_GRPC_SERVICE=
DA_WRITER_GRPC_METHOD=
DA_WRITER_GRPC_PAYLOAD_FIELD=data
DA_WRITER_GRPC_EXTRA_JSON=
DA_WRITER_GRPC_USE_TLS=false
DA_WRITER_GRPC_STATUS_METHOD=GetBlobStatus
DA_WRITER_GRPC_STATUS_POLL_INTERVAL_MS=2500
DA_WRITER_GRPC_STATUS_POLL_MAX_ATTEMPTS=12

# BullMQ / Valkey (required for queue + retries)
REDIS_URL=
REDIS_KEY_PREFIX=ZERO-G-DA-EVENT:
MAX_RETRIES=3
RETRY_BACKOFF_MS=2000
BULLMQ_CONCURRENCY=10
BULLMQ_REMOVE_ON_COMPLETE=1000
BULLMQ_REMOVE_ON_FAIL=5000

# Optional API auth for producers
INGEST_API_KEY=


