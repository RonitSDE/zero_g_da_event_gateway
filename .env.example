PORT=3300

# Mongo is optional but recommended for durability.
MONGO_URL=
MONGO_DB=guesstheai
MONGO_EVENTS_COLLECTION=da_gateway_events
MONGO_BATCHES_COLLECTION=da_gateway_batches

# Queue/batching behavior
DA_BATCH_SIZE=50
DA_FLUSH_INTERVAL_MS=5000
DA_EVENT_MAX_AGE_MS=120000

# Delivery mode: mock | http | grpc
DA_TARGET_MODE=mock

# HTTP upstream target (used when DA_TARGET_MODE=http)
DA_UPSTREAM_URL=
DA_UPSTREAM_API_KEY=
DA_TIMEOUT_MS=12000

# gRPC target placeholders (used when DA_TARGET_MODE=grpc)
DA_GRPC_ENDPOINT=127.0.0.1:51001
DA_GRPC_PROTO_PATH=
DA_GRPC_SERVICE=
DA_GRPC_METHOD=

# Optional API auth for producers
INGEST_API_KEY=
