PORT=3300

# ─── MongoDB (required for durability and status tracking) ───────────────────
MONGO_URL=
MONGO_DB=zero-g-da-events
MONGO_EVENTS_COLLECTION=da_gateway_events
MONGO_BATCHES_COLLECTION=da_gateway_batches

# ─── Queue / batching ────────────────────────────────────────────────────────
DA_BATCH_SIZE=50
DA_FLUSH_INTERVAL_MS=5000
DA_EVENT_MAX_AGE_MS=120000

# ─── Delivery mode ───────────────────────────────────────────────────────────
# DA_TARGET_MODE=local is the production path.
# It uses DA_WRITER_MODE below to route to the 0G DA disperser.
DA_TARGET_MODE=local

# ─── Writer mode (production: grpc) ──────────────────────────────────────────
# grpc  → direct 0G DA disperser call via gRPC (production)
# http  → forward to an intermediate DA writer HTTP service
# mock  → generate fake references (local testing only)
DA_WRITER_MODE=grpc
DA_WRITER_GRPC_ENDPOINT=127.0.0.1:51001
DA_WRITER_GRPC_PROTO_PATH=/opt/zero_g_da_event_gateway/protos/disperser.proto
DA_WRITER_GRPC_SERVICE=disperser.Disperser
DA_WRITER_GRPC_METHOD=DisperseBlob
DA_WRITER_GRPC_PAYLOAD_FIELD=data
DA_WRITER_GRPC_EXTRA_JSON={"security_params":[{"quorum_id":0,"adversary_threshold":33,"quorum_threshold":66}]}
DA_WRITER_GRPC_USE_TLS=false
DA_WRITER_GRPC_STATUS_METHOD=GetBlobStatus
DA_WRITER_GRPC_STATUS_POLL_INTERVAL_MS=2500
DA_WRITER_GRPC_STATUS_POLL_MAX_ATTEMPTS=12
DA_STARTUP_STRICT=true
DA_STARTUP_CHECK_TIMEOUT_MS=8000
# Optional strict startup chain checks (recommended in production)
DA_CHAIN_RPC=
DA_EXPECTED_CHAIN_ID=
DA_ENTRANCE_CONTRACT_ADDR=

# HTTP writer (only when DA_WRITER_MODE=http)
DA_WRITER_UPSTREAM_URL=
DA_WRITER_UPSTREAM_API_KEY=

DA_TIMEOUT_MS=12000

# ─── Legacy direct modes (not recommended; use DA_TARGET_MODE=local above) ──
DA_UPSTREAM_URL=
DA_UPSTREAM_API_KEY=
DA_GRPC_ENDPOINT=127.0.0.1:51001
DA_GRPC_PROTO_PATH=
DA_GRPC_SERVICE=
DA_GRPC_METHOD=

# ─── BullMQ / Valkey ─────────────────────────────────────────────────────────
REDIS_URL=
REDIS_KEY_PREFIX=ZERO-G-DA-EVENT:
MAX_RETRIES=5
RETRY_BACKOFF_MS=2000
BULLMQ_CONCURRENCY=10
BULLMQ_REMOVE_ON_COMPLETE=1000
BULLMQ_REMOVE_ON_FAIL=5000

# ─── Auth (required in production) ───────────────────────────────────────────
# Set REQUIRE_AUTH=true to force the server to reject all requests without a
# valid Bearer token. The server will refuse to start if INGEST_API_KEY is not set.
INGEST_API_KEY=
REQUIRE_AUTH=true

